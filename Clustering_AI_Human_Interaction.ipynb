        "import pandas as pd\n",
        "import numpy as np\n",
        "import re\n",
        "import unicodedata\n",
        "\n",
        "df = pd.read_excel(\"/content/Base_Datos_IA_Unificada_Simple.xlsx\")\n",
        "\n",
        "COL_MUNICIPIO = \"municipio\"\n",
        "COL_PROMPT    = \"prompt_texto\"\n",
        "COL_RESPUESTA = \"respuesta_texto\"\n",
        "\n",
        "df = df.dropna(subset=[COL_PROMPT, COL_RESPUESTA], how=\"all\").copy()\n",
        "\n",
        "print(df[[COL_MUNICIPIO, COL_PROMPT, COL_RESPUESTA]].head())\n",
        "print(\"Total registros:\", len(df))\n"
      ],
