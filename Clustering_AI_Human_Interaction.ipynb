      "cell_type": "markdown",
      "source": [
        "# Clustering"
      ],
      "metadata": {
        "id": "J7LimkOZkKVd"
      }
    },
    {
"cell_type": "markdown",
      "source": [
        "### HDBSCAN (Hierarchical Density-Based Spatial Clustering of Applications with Noise))"
      ],
      "metadata": {
        "id": "1d4fjPtDkLss"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "\n",
        "import itertools\n",
        "import numpy as np\n",
        "import hdbscan\n",
        "\n",
        "configs = []\n",
        "for mcs, ms in itertools.product([5,10,15,20], [1,3,5]):\n",
        "    clusterer = hdbscan.HDBSCAN(min_cluster_size=mcs,\n",
        "                                min_samples=ms)\n",
        "    labels = clusterer.fit_predict(embeddings)\n",
        "\n",
        "    valid_clusters = [c for c in set(labels) if c != -1]\n",
        "    n_clusters = len(valid_clusters)\n",
        "    noise_ratio = (labels == -1).mean()\n",
        "\n",
        "    cluster_sizes = [np.sum(labels == c) for c in valid_clusters]\n",
        "    avg_size = np.mean(cluster_sizes) if cluster_sizes else 0\n",
        "\n",
        "    configs.append({\n",
        "        \"min_cluster_size\": mcs,\n",
        "        \"min_samples\": ms,\n",
        "        \"clusters\": n_clusters,\n",
        "        \"ruido\": noise_ratio,\n",
        "        \"avg_size\": avg_size\n",
        "    })\n",
        "\n",
        "pd.DataFrame(configs)"
      ],
