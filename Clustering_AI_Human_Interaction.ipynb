      "source": [
        "from wordcloud import WordCloud\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "topic_names = {\n",
        "   -1: \"Platos típicos de la región y guisos tradicionales\",\n",
        "    0: \"Preparaciones de trucha\",\n",
        "    1: \"Ingredientes básicos y sazón casera\"\n",
        "\n",
        "}\n",
        "\n",
        "for topic_id in topic_info_df[\"Topic\"].unique():\n",
        "\n",
        "    palabras_pesos = topic_model.get_topic(topic_id)\n",
        "\n",
        "    if not palabras_pesos:\n",
        "        continue\n",
        "\n",
        "    freqs = {word: weight for word, weight in palabras_pesos}\n",
        "\n",
        "    wc = WordCloud(\n",
        "        width=700,\n",
        "        height=450,\n",
        "        background_color=\"white\",\n",
        "        colormap=\"viridis\"\n",
        "    ).generate_from_frequencies(freqs)\n",
        "\n",
        "    plt.figure(figsize=(8,5))\n",
        "    plt.imshow(wc, interpolation=\"bilinear\")\n",
        "    plt.axis(\"off\")\n",
        "\n",
        "    titulo_final = topic_names.get(topic_id, f\"Tópico {topic_id}\")\n",
        "\n",
        "    plt.title(titulo_final, fontsize=13)\n",
        "\n",
        "\n",
        "    plt.show()\n",
        "\n"
      ],
