      "cell_type": "code",
      "source": [
        "\n",
        "from gensim.corpora import Dictionary\n",
        "from gensim.models.coherencemodel import CoherenceModel\n",
        "\n",
        "docs_clean = [doc.split() for doc in docs_cluster]\n",
        "\n",
        "topic_ids = [t for t in topic_model.get_topics().keys() if t != -1]\n",
        "\n",
        "topics_words = []\n",
        "for t in topic_ids:\n",
        "    words = [w for w, _ in topic_model.get_topic(t)]\n",
        "    topics_words.append(words)\n",
        "\n",
        "print(\"Tópicos considerados:\", topic_ids)\n",
        "print(\"Palabras por tópico:\")\n",
        "for tid, words in zip(topic_ids, topics_words):\n",
        "    print(f\"Topic {tid}: {words}\")\n",
        "\n",
        "dictionary = Dictionary(docs_clean)\n",
        "\n",
        "cm_cv = CoherenceModel(\n",
        "    topics=topics_words,\n",
        "    texts=docs_clean,\n",
        "    dictionary=dictionary,\n",
        "    coherence=\"c_v\"\n",
        ")\n",
        "\n",
        "coh_cv_global = cm_cv.get_coherence()\n",
        "coh_cv_by_topic = cm_cv.get_coherence_per_topic()\n",
        "\n",
        "print(\"\\n=== Coherencia global ===\")\n",
        "print(f\"C_v global: {coh_cv_global:.3f}\")\n",
        "\n",
        "print(\"\\n=== Coherencia por tópico ===\")\n",
        "for tid, c in zip(topic_ids, coh_cv_by_topic):\n",
        "    print(f\"Topic {tid}: C_v={c:.3f}\")\n",
        "\n",
        "def topic_diversity(topic_model, top_k=10):\n",
        "    topics = topic_model.get_topics()\n",
        "    if -1 in topics:\n",
        "        del topics[-1]\n",
        "\n",
        "    unique_words = set()\n",
        "    total_words = 0\n",
        "    for t in topics.values():\n",
        "        words = [w for w, _ in t[:top_k]]\n",
        "        unique_words.update(words)\n",
        "        total_words += len(words)\n",
        "\n",
        "    return len(unique_words) / total_words\n",
        "\n",
        "div = topic_diversity(topic_model, top_k=10)\n",
        "print(f\"\\nTopic Diversity: {div:.3f}\")\n",
        "\n"
