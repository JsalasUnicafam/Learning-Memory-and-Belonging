        "\n",
        "\n",
        "from sklearn.feature_extraction.text import CountVectorizer\n",
        "from bertopic import BERTopic\n",
        "import nltk\n",
        "from nltk.corpus import stopwords\n",
        "from umap import UMAP\n",
        "\n",
        "nltk.download(\"stopwords\")\n",
        "\n",
        "stopwords_es = stopwords.words('spanish')\n",
        "\n",
        "stopwords_extra = stopwords_es + [\n",
        "    \"sumerce\", \"video\", \"gracias\", \"hola\", \"buenos\", \"dias\",\n",
        "    \"si\", \"no\", \"usted\", \"pues\", \"aqui\", \"ahi\", \"mas\"\n",
        "]\n",
        "\n",
        "umap_model = UMAP(\n",
        "    n_neighbors=15,\n",
        "    n_components=5,\n",
        "    min_dist=0.0,\n",
        "    metric='cosine',\n",
        "    random_state=99\n",
        ")\n",
        "\n",
        "vectorizer_model = CountVectorizer(\n",
        "    stop_words=stopwords_extra,\n",
        "    ngram_range=(1, 2),\n",
        "    min_df=2\n",
        ")\n",
        "\n",
        "mask = df[\"cluster_final\"] == 0\n",
        "docs_cluster = df.loc[mask, \"texto\"].tolist()\n",
        "emb_cluster = embeddings[mask]\n",
        "\n",
        "topic_model = BERTopic( #Recordar que el modelo es estocastico por lo que los resultados podrian variar un poco aunque seran semanticamente consistentes.\n",
        "    language=\"spanish\",\n",
        "    vectorizer_model=vectorizer_model,\n",
        "    min_topic_size=3, # Aumentar para obtener menos topicos (Se uso 3 para clusters 0,1, y 3. se utilizo 8 para cluster 2. se utilizo 12 para clusters 4 y 5).\n",
        "    top_n_words=10\n",
        ")\n",
        "\n",
        "topics, probs = topic_model.fit_transform(docs_cluster, embeddings=emb_cluster)\n",
        "\n",
        "topic_info_df = topic_model.get_topic_info()\n",
        "\n",
        "pd.set_option('display.max_colwidth', 300)\n",
        "pd.set_option('display.max_rows', None)\n",
        "\n",
        "print(\"\\n=== Información de tópicos BERTopic ===\")\n",
        "display(topic_info_df)\n",
        "\n"
      ],
