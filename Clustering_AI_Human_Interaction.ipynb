    {
"cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import re\n",
        "import unicodedata\n",
        "\n"        "import matplotlib.pyplot as plt\n",
        "\n",
        "def limpiar_texto(s):\n",
        "    if pd.isna(s):\n",
        "        return \"\"\n",
        "    # Pasar a string por si acaso\n",
        "    s = str(s)\n",
        "    # Quitar espacios extremos\n",
        "    s = s.strip()\n",
        "    # Minúsculas\n",
        "    s = s.lower()\n",
        "    # Normalizar acentos\n",
        "    s = unicodedata.normalize(\"NFKD\", s)\n",
        "    s = \"\".join(c for c in s if not unicodedata.combining(c))\n",
        "    # Quitar URLs por si acaso\n",
        "    s = re.sub(r\"http\\S+|www\\.\\S+\", \" \", s)\n",
        "    # Quitar caracteres que no sean letras, números, puntuación básica\n",
        "    s = re.sub(r\"[^a-z0-9áéíóúñü.,;:!?¿¡\\s]\", \" \", s)\n",
        "    # Espacios múltiples\n",
        "    s = re.sub(r\"\\s+\", \" \", s)\n",
        "    return s.strip()\n",
"df[\"texto\"] = (\n",
        "    df[COL_PROMPT].fillna(\"\") + \" || \" + df[COL_RESPUESTA].fillna(\"\")\n",
        ").apply(limpiar_texto)\n",
        "\n",
        "df = df[df[\"texto\"].str.len() > 0].copy()\n",
        "\n",
        "df[[\"municipio\", \"texto\"]].head()\n",
        "\n",
        "total_registros = len(df)\n",
        "print(f\"Total de interacciones válidas: {total_registros}\")\n",
        "\n",
"tabla_mun = (\n",
        "    df[COL_MUNICIPIO]\n",
        "    .value_counts()\n",
        "    .rename(\"frecuencia\")\n",
        "    .to_frame()\n",
        ")\n",
        "\n",
        "tabla_mun[\"porcentaje\"] = (tabla_mun[\"frecuencia\"] / tabla_mun[\"frecuencia\"].sum() * 100).round(1)\n",
        "\n",
        "print(\"\\nDistribución por municipio:\")\n",
        "print(tabla_mun)\n",
        "\n",
        "df[\"longitud_palabras\"] = df[\"texto\"].str.split().str.len()\n",
        "\n",
        "print(\"\\nEstadísticas de longitud del texto (en número de palabras):\")\n",
        "print(df[\"longitud_palabras\"].describe())\n",
        "\n",
        "stats_long_mun = df.groupby(COL_MUNICIPIO)[\"longitud_palabras\"].describe()\n",
        "print(\"\\nLongitud de texto por municipio:\")\n",
        "print(stats_long_mun)\n",
        "\n",
        "\n",
        "plt.figure(figsize=(7, 4))\n",
        "plt.bar(tabla_mun.index, tabla_mun[\"frecuencia\"], color=\"#4A76C5\")\n",
        "plt.xlabel(\"Municipio\")\n",
        "plt.ylabel(\"Número de Interacciones\")\n",
        "plt.title(\"Distribución de Interacciones por Municipio\")\n",
        "plt.grid(axis=\"y\", linestyle=\"--\", alpha=0.5)\n",
        "\n",
        "# Mostrar valores encima de cada barra: número + %\n",
        "for i, (freq, pct) in enumerate(zip(tabla_mun[\"frecuencia\"], tabla_mun[\"porcentaje\"])):\n",
        "    plt.text(i, freq + 1, f\"{freq} ({pct}%)\",\n",
        "             ha='center', va='bottom', fontsize=10)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n"
      ],
