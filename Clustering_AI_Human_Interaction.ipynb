        "import umap\n",
        "import hdbscan\n",
        "\n",
        "umap_reducer = umap.UMAP(\n",
        "    n_neighbors=15,\n",
        "    min_dist=1,\n",
        "    n_components=2,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "emb_2d = umap_reducer.fit_transform(embeddings)\n",
        "df[\"umap_x\"] = emb_2d[:, 0]\n",
        "df[\"umap_y\"] = emb_2d[:, 1]\n",
        "\n",
